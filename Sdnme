6. Mapping + grouping (enterprise style)

Service:

getGroupedTags() {

 return this.http.get<BackendResponse>(this.url).pipe(

   map(res => res.data),

   map(tags => {

     const grouped: any = {};

     tags.forEach(tag => {

       const category = tag.TAG_CAT_CD;

       if (!grouped[category]) {
         grouped[category] = [];
       }

       grouped[category].push({
         value: tag.TAG_CD,
         label: tag.TAG_DESC
       });

     });

     return Object.keys(grouped).map(cat => ({
       category: cat,
       tags: grouped[cat]
     }));

   })

 );
}


