6. Business Rule Component

Container fetches backend data.

@Component({
  providers: [TagDataSource]
})
export class AddBusinessRuleComponent {

  constructor(
    private tagService: TagService,
    private dataSource: TagDataSource
  ) {}

  ngOnInit() {

    this.tagService.getTags().subscribe(tags => {
      this.dataSource.setTags(tags);
    });

  }

}

Each rule component gets its own datasource instance.


