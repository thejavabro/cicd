4. Reusable TagSearchComponent

Implemented as ControlValueAccessor so it plugs directly into your form.

<app-tag-search formControlName="ruleTags"></app-tag-search>


---

Component

@Component({
  selector: 'app-tag-search',
  providers: [{
    provide: NG_VALUE_ACCESSOR,
    useExisting: forwardRef(() => TagSearchComponent),
    multi: true
  }]
})
export class TagSearchComponent implements ControlValueAccessor {

  dataSource = inject(TagDataSource);

  searchCtrl = new FormControl('');

  filteredTags = signal<Tag[]>([]);

  selectedTags: Tag[] = [];

  ngOnInit() {

    this.filteredTags.set(this.dataSource.all());

    this.searchCtrl.valueChanges
      .pipe(debounceTime(200))
      .subscribe(value => {
        this.filteredTags.set(
          this.dataSource.filter(value || '')
        );
      });

  }

  toggle(tag: Tag) {

    const exists = this.selectedTags.find(t => t.label === tag.label);

    if (exists) {
      this.selectedTags = this.selectedTags.filter(t => t.label !== tag.label);
    } else {
      this.selectedTags = [...this.selectedTags, tag];
    }

    this.onChange(this.selectedTags);
  }

  remove(tag: Tag) {
    this.toggle(tag);
  }

  writeValue(tags: Tag[]) {
    this.selectedTags = tags || [];
  }

  onChange = (_: any) => {};
  onTouched = () => {};
}

Notice:

No backend

No inputs

No outputs

Pure UI behavior



