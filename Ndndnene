3. TagDataSource (Key Enterprise Pattern)

This separates data logic from the UI component.

import { signal } from '@angular/core';

export class TagDataSource {

  private tags = signal<Tag[]>([]);

  setTags(tags: Tag[]) {
    this.tags.set(tags);
  }

  filter(query: string): Tag[] {

    const list = this.tags().filter(tag =>
      tag.label.toLowerCase().includes(query.toLowerCase())
    );

    if (!list.length && query) {
      list.push({
        label: query,
        category: 'USER',
        isNew: true
      });
    }

    return list;
  }

  all() {
    return this.tags();
  }
}

Benefits:

Keeps component logic small

Reusable

Easily testable



