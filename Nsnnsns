import { map } from 'rxjs/operators';
import { Tag } from '../components/tag-search/models/tag.model';

public getRuleTags(): Observable<Tag[]> {

  const ruleTagsPayload: DqrmDataPayload = {

    filterModel: {},

    sortModel: [],

    groupKeys: [],

    pivotCols: [],

    pivotMode: false,

    rowGroupCols: [],

    valueCols: [],

    startRow: -1,   // important

    endRow: -1,

    queryName: "RULE_TAGS",

    searchMode: "LIVE_SEARCH",

    searchFeaturesRequested: ["TOP_RECORDS_LIVE_SEARCH"]

  };

  return this.dqrmDataClient
    .getDqrmDatas(ruleTagsPayload)
    .pipe(
      map((response: any) =>
        response.data.map((t: any) => ({
          code: t.TAG_CD,
          label: t.TAG_DESC,
          category: t.TAG_CAT_CD === 'STD' ? 'SYSTEM' : 'USER'
        }))
      )
    );
}

