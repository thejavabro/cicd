import {
  Component,
  ChangeDetectionStrategy,
  forwardRef,
  inject,
  signal
} from '@angular/core';

import {
  ControlValueAccessor,
  NG_VALUE_ACCESSOR,
  FormControl
} from '@angular/forms';

import { debounceTime } from 'rxjs';

import { Tag } from './models/tag.model';
import { TagDataSource } from './data-source/tag-data-source';

@Component({

  selector: 'tag-search',

  templateUrl: './tag-search.component.html',

  styleUrls: ['./tag-search.component.scss'],

  providers: [
    {
      provide: NG_VALUE_ACCESSOR,
      useExisting: forwardRef(() => TagSearchComponent),
      multi: true
    },
    TagDataSource
  ],

  changeDetection: ChangeDetectionStrategy.OnPush

})
export class TagSearchComponent implements ControlValueAccessor {

  dataSource = inject(TagDataSource);

  searchCtrl = new FormControl('');

  filteredTags = signal<Tag[]>([]);

  selectedTags: Tag[] = [];

  disabled = false;

  ngOnInit() {

    this.filteredTags.set(this.dataSource.getAll());

    this.searchCtrl.valueChanges
      .pipe(debounceTime(200))
      .subscribe(value => {

        const query = value ?? '';

        this.filteredTags.set(
          this.dataSource.filter(query)
        );

      });
  }

  toggle(tag: Tag) {

    if (this.disabled) return;

    const exists = this.selectedTags.find(t => t.label === tag.label);

    if (exists) {

      this.selectedTags =
        this.selectedTags.filter(t => t.label !== tag.label);

    } else {

      this.selectedTags = [...this.selectedTags, tag];

    }

    this.onChange(this.selectedTags);
  }

  remove(tag: Tag) {

    this.toggle(tag);

  }

  isSelected(tag: Tag): boolean {

    return this.selectedTags.some(t => t.label === tag.label);

  }

  writeValue(tags: Tag[]): void {

    this.selectedTags = tags || [];

  }

  registerOnChange(fn: any): void {

    this.onChange = fn;

  }

  registerOnTouched(fn: any): void {

    this.onTouched = fn;

  }

  setDisabledState(isDisabled: boolean): void {

    this.disabled = isDisabled;

  }

  onChange: any = () => {};
  onTouched: any = () => {};
}


