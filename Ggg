import { signal } from '@angular/core';
import { Tag } from '../models/tag.model';

export class TagDataSource {

  private tags = signal<Tag[]>([]);

  setTags(tags: Tag[]) {
    this.tags.set(tags);
  }

  getAll(): Tag[] {
    return this.tags();
  }

  filter(query: string): Tag[] {

    const result = this.tags().filter(tag =>
      tag.label.toLowerCase().includes(query.toLowerCase())
    );

    if (query && result.length === 0) {
      result.push({
        label: query,
        category: 'USER',
        isNew: true
      });
    }

    return result;
  }
}


