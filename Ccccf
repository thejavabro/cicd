The error is happening because response.data is not typed as RuleTagBackend[].
TypeScript currently thinks each item is { [key: string]: string | number }, so when you declare:

(item: RuleTagBackend)

TypeScript says the types are incompatible.

You need to cast response.data to RuleTagBackend[] before mapping.

Below is the correct production-safe approach for your component.


---

Correct Code for Your Component Class

import { Component, OnInit } from '@angular/core';
import { map } from 'rxjs/operators';
import { Observable } from 'rxjs';

import { DqrmService } from '../services/dqrm.service';
import { RuleTagBackend, RuleTag } from '../models/RuleTag';

@Component({
  selector: 'app-add-business-rule',
  templateUrl: './add-business-rule.component.html'
})
export class AddBusinessRuleComponent implements OnInit {

  ruleTags$!: Observable<RuleTag[]>;
  selected: RuleTag | null = null;

  viewFields = [
    { key: 'tag', label: 'Tag', flex: 3, minWidth: 160 },
    { key: 'category', label: 'Category', flex: 2 }
  ];

  constructor(private dqrmService: DqrmService) {}

  ngOnInit(): void {

    const ruleTagsPayload = {
      endRow: -1,
      queryName: "RULE_TAGS",
      searchFeaturesRequested: ["TOP_RECORDS_LIVE_SEARCH"],
      searchMode: "LIVE_SEARCH",
      startRow: 0
    };

    this.ruleTags$ = this.dqrmService.getRuleTags(ruleTagsPayload).pipe(

      map((response: any) => {
        const backendData = response.data as RuleTagBackend[];

        return backendData.map(item => ({
          tagCode: item.TAG_CD,
          tag: item.TAG_DESC,
          category: item.TAG_CAT_CD
        }));
      })

    );
  }
}


